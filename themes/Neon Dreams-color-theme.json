	"semanticTokenColors": {
		"class": "#4f8cff",
		"interface": "#4f8cff",
		"enum": "#4f8cff",
		"type": "#4f8cff",
		"typeParameter": "#9fcf9f",
		"function": "#66f2a8",
		"method": "#66f2a8",
		"macro": "#00e87a",
		"property": "#d8f5d8",
		"variable": "#d8f5d8",
		"parameter": "#9fcf9f",
		"keyword": {
			"foreground": "#00e87a",
			"bold": true
		},
		"string": "#9fcf9f",
		"number": "#4f8cff",
		"comment": {
			"foreground": "#6f936f",
			"italic": true
		}
	},
	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#6f936f",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables and default text",
			"scope": [
				"variable"
			],
			"settings": {
				"foreground": "#d8f5d8"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#00e87a",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Operators and punctuation",
			"scope": [
				"keyword.operator",
				"punctuation",
				"punctuation.separator",
				"punctuation.terminator"
			],
			"settings": {
				"foreground": "#9fcf9f"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#9fcf9f"
			}
		},
		{
			"name": "Numbers and constants",
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#4f8cff"
			}
		},
		{
			"name": "Functions and methods",
			"scope": [
				"entity.name.function",
				"support.function",
				"variable.function"
			],
			"settings": {
				"foreground": "#66f2a8"
			}
		},
		{
			"name": "Classes, types and interfaces",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"support.type",
				"support.class"
			],
			"settings": {
				"foreground": "#4f8cff"
			}
		},
		{
			"name": "Properties and object keys",
			"scope": [
				"variable.other.property",
				"meta.object-literal.key",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#d8f5d8"
			}
		},
		{
			"name": "Decorators and annotations",
			"scope": [
				"meta.decorator",
				"entity.name.function.decorator"
			],
			"settings": {
				"foreground": "#ffd166"
			}
		},
		{
			"name": "Invalid syntax",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#ff4d6d"
			}
		},
		{
			"name": "Markdown headings",
			"scope": [
				"markup.heading",
				"entity.name.section.markdown"
			],
			"settings": {
				"foreground": "#00e87a",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown inline code",
			"scope": [
				"markup.inline.raw.markdown"
			],
			"settings": {
				"foreground": "#66f2a8"
			}
		},
		{
			"name": "Markdown quote",
			"scope": [
				"markup.quote.markdown"
			],
			"settings": {
				"foreground": "#9fcf9f",
				"fontStyle": "italic"
			}
		}
	]
}
